#!/usr/bin/env ruby
# frozen_string_literal: true

require 'fileutils'
require 'yaml'

# Color output helpers
def green(text)
  "\e[32m#{text}\e[0m"
end

def yellow(text)
  "\e[33m#{text}\e[0m"
end

def red(text)
  "\e[31m#{text}\e[0m"
end

def blue(text)
  "\e[34m#{text}\e[0m"
end

def bold(text)
  "\e[1m#{text}\e[0m"
end

def prompt(question, default = nil)
  print blue("#{question}")
  print " [#{default}]" if default
  print ": "
  answer = gets.chomp
  answer.empty? && default ? default : answer
end

def confirm(question)
  answer = prompt("#{question} (y/n)", "n").downcase
  answer == 'y' || answer == 'yes'
end

# Main script
puts bold("\n=== BootKit Initialization Wizard ===\n")
puts "This script will help you set up BootKit for your own use.\n\n"

puts yellow("⚠️  WARNING ⚠️")
puts "This will remove Andre's personal dotfiles from this repository."
puts "The following will be cleaned up:"
puts "  • All files in dotfiles/ directory"
puts "  • Existing bootkit.yml (if present)"
puts "  • Existing config.yaml will be reset to a minimal template\n\n"

unless confirm("Do you want to continue?")
  puts red("Initialization cancelled.")
  exit 1
end

# Step 1: Clean up personal files
puts "\n#{green('Step 1:')} Cleaning up personal files..."

bootkit_root = File.expand_path('..', __dir__)
dotfiles_dir = File.join(bootkit_root, 'dotfiles')
bootkit_yml = File.join(bootkit_root, 'bootkit.yml')
config_yaml = File.join(bootkit_root, 'config.yaml')

# Remove all dotfiles
if Dir.exist?(dotfiles_dir)
  FileUtils.rm_rf(Dir.glob("#{dotfiles_dir}/*"))
  puts "  ✓ Cleared dotfiles/ directory"
else
  FileUtils.mkdir_p(dotfiles_dir)
  puts "  ✓ Created dotfiles/ directory"
end

# Remove bootkit.yml if it exists
if File.exist?(bootkit_yml)
  FileUtils.rm(bootkit_yml)
  puts "  ✓ Removed existing bootkit.yml"
end

# Step 2: Gather user information
puts "\n#{green('Step 2:')} Gathering your configuration..."
puts "Please answer the following questions:\n\n"

vault_name = prompt("1Password vault name", "Dotfiles")
gpg_key_path = prompt("GPG key path in 1Password (e.g., 'GPG Key/notes')", "GPG Key/notes")
profile_name = prompt("Dotdrop profile name (usually your hostname)", `hostname`.chomp.strip)
gpg_key_id = prompt("GPG key ID (optional, press Enter to skip)", "~")
log_level = prompt("Logging level (debug/info/warn/error)", "info")

# Step 3: Generate bootkit.yml
puts "\n#{green('Step 3:')} Generating bootkit.yml..."

bootkit_config = {
  'logging' => {
    'level' => log_level
  },
  'onepassword' => {
    'vault' => vault_name,
    'gpg_key_path' => gpg_key_path
  },
  'gpg' => {
    'key_id' => gpg_key_id == '~' ? nil : gpg_key_id
  },
  'dotdrop' => {
    'profile' => profile_name
  }
}

File.write(bootkit_yml, bootkit_config.to_yaml)
puts "  ✓ Created bootkit.yml"

# Step 4: Generate minimal config.yaml for Dotdrop
puts "\n#{green('Step 4:')} Generating minimal config.yaml for Dotdrop..."

dotdrop_config = {
  'config' => {
    'backup' => true,
    'banner' => true,
    'create' => true,
    'dotpath' => 'dotfiles',
    'ignoreempty' => false,
    'keepdot' => false,
    'longkey' => false,
    'showdiff' => true,
    'workdir' => '~/.config/dotdrop'
  },
  'dotfiles' => {
    # Empty - user will add their dotfiles here
  },
  'profiles' => {
    profile_name => {
      'dotfiles' => []
    }
  },
  'trans_install' => {
    '_decrypt' => 'gpg -q --for-your-eyes-only --no-tty -d {0} > {1}'
  },
  'trans_update' => {
    '_encrypt' => 'gpg -qaer {2} -o {1} {0}'
  }
}

File.write(config_yaml, dotdrop_config.to_yaml)
puts "  ✓ Created config.yaml with profile '#{profile_name}'"

# Step 5: Display next steps
puts "\n#{green('✓ Initialization complete!')}\n\n"
puts bold("Next steps:")
puts "  1. #{blue('Add your dotfiles')} to the dotfiles/ directory"
puts "     Example: cp ~/.zshrc dotfiles/zshrc"
puts ""
puts "  2. #{blue('Configure Dotdrop')} in config.yaml to map your dotfiles"
puts "     • Add entries to 'dotfiles:' section"
puts "     • Add them to your profile's 'dotfiles:' list"
puts "     • See: https://dotdrop.readthedocs.io/en/latest/"
puts ""
puts "  3. #{blue('Customize your Brewfile')} with packages you want installed"
puts "     Edit: #{File.join(bootkit_root, 'Brewfile')}"
puts ""
puts "  4. #{blue('Run the installer')} to deploy on this machine"
puts "     ./bin/install"
puts ""
puts "  5. #{blue('Commit your changes')} to your own Git repository"
puts "     git add ."
puts "     git commit -m 'Initialize my BootKit'"
puts "     git remote set-url origin <your-repo-url>"
puts "     git push"
puts ""
puts "#{yellow('Note:')} Store your GPG key in 1Password (vault: '#{vault_name}')"
puts "       as a Secure Note at the path: #{gpg_key_path}"
puts ""
puts "For detailed documentation, see: #{File.join(bootkit_root, 'README.md')}"
puts ""
